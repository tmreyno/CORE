{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CORE-FFX",
  "version": "0.1.49",
  "identifier": "com.core-ffx.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "CORE-FFX",
        "width": 1100,
        "height": 720,
        "minWidth": 960,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' http://localhost:* https://localhost:* http://127.0.0.1:* https://api.openai.com; img-src 'self' data: blob:; font-src 'self' data:; worker-src 'self' blob:"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/tmreyno/CORE/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDlCN0U5NzBBNEYzRjU3RUEKUldUcVZ6OVBDcGQrbS9iOGE4U0w1bE1Ed2M0dVF5ZlVYM1BTV1FISHNvdXU2UUJzUGx3OC83KzcK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "Entitlements.plist",
      "signingIdentity": null,
      "hardenedRuntime": true
    },
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "allowDowngrades": true
    }
  }
}
