{
  "id": "evidence_collection",
  "name": "Evidence Collection",
  "version": "1.1.0",
  "description": "Documentation of evidence collection including locations, conditions, and packaging for each collected item. Device identifiers, forensic image details, and acquisition metadata are automatically populated from evidence container headers.",
  "icon": "📦",
  "report_types": ["evidence_collection", "forensic_examination"],
  "effective_date": "2025-01-01",
  "sections": [
    {
      "id": "collection_header",
      "title": "Collection Details",
      "icon": "📦",
      "layout": { "columns": 2 },
      "fields": [
        {
          "id": "collection_date",
          "label": "Collection Date/Time",
          "type": "datetime",
          "validation": { "required": true },
          "help": "Date/time collection operation began"
        },
        {
          "id": "collecting_officer",
          "label": "Collecting Officer/Examiner",
          "type": "text",
          "validation": { "required": true },
          "auto_fill": { "source": "examiner", "path": "name" }
        },
        {
          "id": "authorization",
          "label": "Authorization (Warrant/Consent)",
          "type": "text",
          "placeholder": "e.g., SW 2026-1234"
        },
        {
          "id": "authorization_date",
          "label": "Authorization Date",
          "type": "date"
        },
        {
          "id": "authorizing_authority",
          "label": "Authorizing Authority",
          "type": "text",
          "placeholder": "e.g., Judge J. Williams"
        },
        {
          "id": "witnesses",
          "label": "Witnesses",
          "type": "comma_list",
          "placeholder": "e.g., Officer A, Officer B",
          "help": "Names separated by commas",
          "col_span": 2
        }
      ]
    },
    {
      "id": "collected_items",
      "title": "Collected Items",
      "icon": "💾",
      "repeatable": true,
      "repeatable_config": {
        "item_label": "Evidence Item",
        "min_items": 0,
        "max_items": 100,
        "summary_fields": ["device_type", "description", "condition"],
        "collapsible": true,
        "number_field": "item_number",
        "number_format": "case_prefix"
      },
      "layout": { "columns": 2 },
      "fields": [
        {
          "id": "item_number",
          "label": "Item Number",
          "type": "text",
          "validation": { "required": true },
          "help": "Auto-generated from case number"
        },
        {
          "id": "description",
          "label": "Description",
          "type": "text",
          "placeholder": "Brief description of the item",
          "col_span": 2
        },

        { "id": "_heading_device", "label": "Device Identification", "type": "heading", "icon": "🖥️", "col_span": 2 },
        {
          "id": "device_type",
          "label": "Device Type",
          "type": "select",
          "options_ref": "device_types",
          "default": "desktop_computer",
          "other_field": "device_type_other"
        },
        {
          "id": "device_type_other",
          "label": "Other Device Type",
          "type": "text",
          "placeholder": "Specify device type...",
          "show_when": { "field": "device_type", "op": "eq", "value": "other" }
        },
        {
          "id": "storage_interface",
          "label": "Storage Interface",
          "type": "select",
          "options_ref": "storage_interface_types",
          "default": "sata",
          "other_field": "storage_interface_other",
          "help": "Internal bus type. Win: Get-CimInstance Win32_DiskDrive | Select InterfaceType,Model | Mac: diskutil info disk0 | Linux: lsblk -d -o NAME,TRAN",
          "options_filter": [
            { "field": "device_type", "filter_map": "device_to_storage_interface" },
            { "field": "form_factor", "filter_map": "form_factor_to_storage_interface" }
          ]
        },
        {
          "id": "storage_interface_other",
          "label": "Other Interface",
          "type": "text",
          "placeholder": "Specify interface type...",
          "show_when": { "field": "storage_interface", "op": "eq", "value": "other" }
        },
        {
          "id": "form_factor",
          "label": "Form Factor",
          "type": "select",
          "options_ref": "form_factors",
          "other_field": "form_factor_other",
          "options_filter": { "field": "device_type", "filter_map": "device_to_form_factor" }
        },
        {
          "id": "form_factor_other",
          "label": "Other Form Factor",
          "type": "text",
          "placeholder": "Specify form factor...",
          "show_when": { "field": "form_factor", "op": "eq", "value": "other" }
        },
        {
          "id": "color",
          "label": "Color",
          "type": "text",
          "placeholder": "e.g., Black"
        },

        { "id": "_heading_location", "label": "Location", "type": "heading", "icon": "📍", "col_span": 2 },
        {
          "id": "building",
          "label": "Building",
          "type": "text",
          "placeholder": "Building name or address"
        },
        {
          "id": "room",
          "label": "Room",
          "type": "text",
          "placeholder": "Room number or description"
        },
        {
          "id": "location_other",
          "label": "Other Location Details",
          "type": "text",
          "placeholder": "Floor, cubicle, desk, vehicle, etc.",
          "col_span": 2
        },

        { "id": "_heading_condition", "label": "Condition & Packaging", "type": "heading", "icon": "📦", "col_span": 2 },
        {
          "id": "condition",
          "label": "Condition",
          "type": "select",
          "options_ref": "evidence_conditions",
          "default": "good"
        },
        {
          "id": "packaging",
          "label": "Packaging",
          "type": "text",
          "placeholder": "e.g., Anti-static bag, evidence bag #1234"
        },

        { "id": "_heading_notes", "label": "Notes", "type": "heading", "icon": "📝", "col_span": 2 },
        {
          "id": "notes",
          "label": "Notes",
          "type": "textarea",
          "rows": 3,
          "placeholder": "Passwords, BitLocker, encryption, phone details, device user details...",
          "col_span": 2
        }
      ]
    },
    {
      "id": "documentation",
      "title": "Documentation",
      "icon": "📷",
      "layout": { "columns": 1 },
      "collapsible": true,
      "fields": [
        {
          "id": "documentation_notes",
          "label": "Photography/Documentation Notes",
          "type": "textarea",
          "rows": 3,
          "placeholder": "Notes about photos taken, documentation procedures..."
        },
        {
          "id": "conditions",
          "label": "Environmental Conditions",
          "type": "textarea",
          "rows": 2,
          "placeholder": "Weather, lighting, environmental factors..."
        }
      ]
    }
  ]
}
