{
  "id": "evidence_collection",
  "name": "Evidence Collection",
  "version": "1.3.0",
  "description": "Documentation of evidence collection including identification, location, device details, and forensic container metadata for each collected item. Device identifiers, forensic image details, and acquisition metadata are automatically populated from evidence container headers.",
  "icon": "📦",
  "report_types": ["evidence_collection", "forensic_examination"],
  "effective_date": "2025-01-01",
  "sections": [
    {
      "id": "collection_header",
      "title": "Collection Details",
      "icon": "📦",
      "layout": { "columns": 3 },
      "fields": [
        {
          "id": "collection_date",
          "label": "Collection Date/Time",
          "type": "datetime",
          "validation": { "required": true },
          "help": "Date/time collection operation began"
        },
        {
          "id": "collecting_officer",
          "label": "Collecting Officer/Examiner",
          "type": "text",
          "validation": { "required": true },
          "auto_fill": { "source": "examiner", "path": "name" }
        },
        {
          "id": "authorizing_authority",
          "label": "Authorizing Authority",
          "type": "text",
          "placeholder": "e.g., Judge J. Williams"
        },
        {
          "id": "authorization",
          "label": "Authorization (Warrant/Consent)",
          "type": "text",
          "placeholder": "e.g., SW 2026-1234"
        },
        {
          "id": "authorization_date",
          "label": "Authorization Date",
          "type": "date"
        },
        {
          "id": "witnesses",
          "label": "Witnesses",
          "type": "comma_list",
          "placeholder": "e.g., Officer A, Officer B",
          "help": "Names separated by commas"
        }
      ]
    },
    {
      "id": "collected_items",
      "title": "Collected Items",
      "icon": "💾",
      "repeatable": true,
      "repeatable_config": {
        "item_label": "Evidence Item",
        "min_items": 0,
        "max_items": 100,
        "summary_fields": ["item_number", "description", "device_type"],
        "collapsible": true,
        "number_field": "item_number",
        "number_format": "case_prefix"
      },
      "layout": { "columns": 3 },
      "fields": [
        {
          "id": "item_number",
          "label": "Evidence Number",
          "type": "text",
          "validation": { "required": true },
          "help": "Auto-generated from case number (e.g., 2026-1234-EV-0001)"
        },
        {
          "id": "evidence_file_id",
          "label": "Evidence Container",
          "type": "text",
          "placeholder": "Linked forensic container or archive",
          "col_span": 2,
          "help": "Auto-populated with the forensic container path (E01, AD1, L01, UFDR, etc.)"
        },

        { "id": "_heading_description", "label": "Evidence Description & Packaging", "type": "heading", "icon": "📋", "col_span": 3 },
        {
          "id": "description",
          "label": "Description",
          "type": "text",
          "placeholder": "Brief description of the item (e.g., Black Dell Latitude laptop)",
          "col_span": 3
        },
        {
          "id": "condition",
          "label": "Condition",
          "type": "select",
          "options_ref": "evidence_conditions",
          "default": "good"
        },
        {
          "id": "packaging",
          "label": "Packaging",
          "type": "text",
          "placeholder": "e.g., Anti-static bag, evidence bag #1234"
        },
        {
          "id": "photo_refs",
          "label": "Photo References",
          "type": "comma_list",
          "placeholder": "e.g., IMG_001, IMG_002",
          "help": "Photo IDs documenting this item"
        },

        { "id": "_heading_location", "label": "Collection Location", "type": "heading", "icon": "📍", "col_span": 3 },
        {
          "id": "building",
          "label": "Building / Address",
          "type": "text",
          "placeholder": "Building name, street address, or search warrant location"
        },
        {
          "id": "room",
          "label": "Room / Area",
          "type": "text",
          "placeholder": "Room number, floor, area description"
        },
        {
          "id": "location_other",
          "label": "Other Location Details",
          "type": "text",
          "placeholder": "Cubicle, desk, vehicle, safe, closet, etc."
        },

        { "id": "_heading_device", "label": "Device Information", "type": "heading", "icon": "🖥️", "col_span": 3 },
        {
          "id": "device_type",
          "label": "Device Type",
          "type": "select",
          "options_ref": "device_types",
          "default": "desktop_computer",
          "other_field": "device_type_other"
        },
        {
          "id": "device_type_other",
          "label": "Other Device Type",
          "type": "text",
          "placeholder": "Specify device type...",
          "show_when": { "field": "device_type", "op": "eq", "value": "other" }
        },
        {
          "id": "color",
          "label": "Color",
          "type": "text",
          "placeholder": "e.g., Black, Silver, Space Gray"
        },
        {
          "id": "brand",
          "label": "Brand / Manufacturer",
          "type": "text",
          "placeholder": "e.g., Dell, Apple, Samsung",
          "help": "Auto-populated from container metadata when available"
        },
        {
          "id": "make",
          "label": "Make",
          "type": "text",
          "placeholder": "e.g., Latitude, MacBook Pro, Galaxy",
          "help": "Device product line or series"
        },
        {
          "id": "model",
          "label": "Model",
          "type": "text",
          "placeholder": "e.g., 5520, A2442, SM-G998U",
          "help": "Auto-populated from E01/UFED container headers"
        },
        {
          "id": "serial_number",
          "label": "Serial Number",
          "type": "text",
          "placeholder": "Device serial number",
          "help": "Auto-populated from E01/UFED container headers"
        },
        {
          "id": "imei",
          "label": "IMEI",
          "type": "text",
          "placeholder": "Mobile device IMEI",
          "show_when": { "field": "device_type", "op": "in", "value": ["mobile_phone", "tablet", "satellite_phone", "other"] },
          "help": "Auto-populated from UFED extractions"
        },
        {
          "id": "other_identifiers",
          "label": "Other Identifiers",
          "type": "text",
          "placeholder": "ICCID, Volume Serial, Asset Tag, MAC Address...",
          "col_span": 3,
          "help": "Additional device identifiers (auto-populated from container metadata)"
        },
        {
          "id": "storage_interface",
          "label": "Storage Interface",
          "type": "select",
          "options_ref": "storage_interface_types",
          "default": "sata",
          "other_field": "storage_interface_other",
          "help": "Internal bus type (auto-filtered by device type)",
          "options_filter": [
            { "field": "device_type", "filter_map": "device_to_storage_interface" },
            { "field": "form_factor", "filter_map": "form_factor_to_storage_interface" }
          ],
          "show_when": { "field": "device_type", "op": "in", "value": ["desktop_computer", "laptop", "server", "nas", "external_drive", "internal_drive", "flash_drive", "memory_card", "other"] }
        },
        {
          "id": "storage_interface_other",
          "label": "Other Interface",
          "type": "text",
          "placeholder": "Specify interface type...",
          "show_when": { "field": "storage_interface", "op": "eq", "value": "other" }
        },
        {
          "id": "form_factor",
          "label": "Form Factor",
          "type": "select",
          "options_ref": "form_factors",
          "other_field": "form_factor_other",
          "options_filter": { "field": "device_type", "filter_map": "device_to_form_factor" },
          "show_when": { "field": "device_type", "op": "in", "value": ["desktop_computer", "laptop", "server", "nas", "external_drive", "internal_drive", "other"] }
        },
        {
          "id": "form_factor_other",
          "label": "Other Form Factor",
          "type": "text",
          "placeholder": "Specify form factor...",
          "show_when": { "field": "form_factor", "op": "eq", "value": "other" }
        },

        { "id": "_heading_forensic", "label": "Forensic Container Details", "type": "heading", "icon": "🔬", "col_span": 3 },
        {
          "id": "image_format",
          "label": "Image Format",
          "type": "select",
          "options_ref": "image_format_options",
          "other_field": "image_format_other",
          "help": "Auto-populated from container type (E01, AD1, L01, etc.)"
        },
        {
          "id": "image_format_other",
          "label": "Other Format",
          "type": "text",
          "placeholder": "Specify image format...",
          "show_when": { "field": "image_format", "op": "eq", "value": "other" }
        },
        {
          "id": "acquisition_method",
          "label": "Acquisition Method",
          "type": "select",
          "options_ref": "acquisition_methods",
          "other_field": "acquisition_method_other",
          "options_filter": { "field": "device_type", "filter_map": "device_to_acquisition_method" },
          "help": "Auto-populated from AD1/UFED extraction metadata"
        },
        {
          "id": "acquisition_method_other",
          "label": "Other Method",
          "type": "text",
          "placeholder": "Specify acquisition method...",
          "show_when": { "field": "acquisition_method", "op": "eq", "value": "other" }
        },
        {
          "id": "item_collection_datetime",
          "label": "Acquisition Date/Time",
          "type": "datetime",
          "help": "Auto-populated from E01 acquiry_date or UFED extraction start time"
        },
        {
          "id": "item_system_datetime",
          "label": "System Date/Time at Acquisition",
          "type": "datetime",
          "help": "System clock at time of acquisition (from E01 header)"
        },
        {
          "id": "item_collecting_officer",
          "label": "Acquiring Examiner",
          "type": "text",
          "placeholder": "Examiner who performed the acquisition",
          "help": "Defaults to collection header examiner; auto-populated from E01 header or companion log"
        },
        {
          "id": "item_authorization",
          "label": "Item-Specific Authorization",
          "type": "text",
          "placeholder": "Only if different from collection header authorization"
        },
        {
          "id": "storage_notes",
          "label": "Container / Acquisition Notes",
          "type": "textarea",
          "rows": 2,
          "placeholder": "Image size, hash values, acquisition tool info...",
          "col_span": 3,
          "help": "Auto-populated with image size, compression, tool info from container metadata"
        },

        { "id": "_heading_notes", "label": "Notes", "type": "heading", "icon": "📝", "col_span": 3 },
        {
          "id": "notes",
          "label": "Notes",
          "type": "textarea",
          "rows": 3,
          "placeholder": "Passwords, BitLocker, encryption, phone lock state, device user details...",
          "col_span": 3
        }
      ]
    },
    {
      "id": "documentation",
      "title": "Documentation",
      "icon": "📷",
      "layout": { "columns": 1 },
      "collapsible": true,
      "fields": [
        {
          "id": "documentation_notes",
          "label": "Photography/Documentation Notes",
          "type": "textarea",
          "rows": 3,
          "placeholder": "Notes about photos taken, documentation procedures..."
        },
        {
          "id": "conditions",
          "label": "Environmental Conditions",
          "type": "textarea",
          "rows": 2,
          "placeholder": "Weather, lighting, environmental factors..."
        }
      ]
    }
  ]
}
