{
  "name": "core-ffx",
  "version": "0.1.35",
  "description": "CORE-FFX - Case Organization & Reporting Ecosystem: Forensic File Explorer",
  "type": "module",
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "build": "vite build",
    "serve": "vite preview",
    "tauri": "tauri",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist node_modules/.vite src-tauri/target",
    "clean:app": "rm -rf ~/Library/Application\\ Support/com.core-ffx.app ~/Library/Caches/com.core-ffx.app",
    "clean:all": "npm run clean && npm run clean:app",
    "tauri:clean": "npm run clean && tauri dev",
    "tauri:fresh": "npm run clean:all && tauri dev"
  },
  "license": "MIT",
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@solid-primitives/event-listener": "^2.3.3",
    "@solid-primitives/keyboard": "^1.2.8",
    "@solid-primitives/resize-observer": "^2.0.26",
    "@solid-primitives/scheduled": "^1.4.3",
    "@solid-primitives/storage": "^4.2.1",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.0",
    "dompurify": "^3.3.2",
    "pdfjs-dist": "^4.10.38",
    "solid-icons": "^1.1.0",
    "solid-js": "^1.9.11"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^25.2.3",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.23",
    "jsdom": "^25.0.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vite-plugin-solid": "^2.11.0",
    "vitest": "^4.0.18"
  }
}
